EXPO_PUBLIC_FINNHUB_API_KEY=your_finnhub_api_key

# Optional — enables real historical charts for US stocks/ETFs.
# Without it, stock charts fall back to Stooq, then to a synthetic series.
# Crypto/commodities/forex charts use Binance and need no key.
EXPO_PUBLIC_ALPHAVANTAGE_API_KEY=your_alphavantage_api_key
